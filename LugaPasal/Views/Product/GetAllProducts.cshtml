@model List<LugaPasal.Entities.Products>

<div class="container">
    <div class="border-bottom mb-3 border-1" style="border-color:#9ca3af">
        <h2 class="text-uppercase text-dark"
            style="letter-spacing:0.5px;font-family:'Poppins', 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif">
            All Products
        </h2>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden rounded-4">
        <div class="card-header" style="background-color:#fafafa;">
            <div class="row fw-semibold text-center align-items-center py-2">
                <div class="col">Product Name</div>
                <div class="col">User</div>
                <div class="col">Price</div>
                <div class="col">Quantity</div>
                <div class="col">Actions</div>
            </div>
        </div>

        <div class="card-body bg-white pt-0">
            @foreach (var product in Model)
            {
                <div class="row text-center py-3 border-bottom user-row align-items-center">
                    <div class="col text-truncate">@product.ProductName</div>
                    <div class="col">@product.User.UserName</div>
                    <div class="col">@product.ProductPrice</div>
                    <div class="col">@product.ProductQuantity</div>
                    <div class="col d-flex justify-content-center align-items-center gap-2">
                        <a asp-controller="User" asp-action="ProductProfile" asp-route-id="@product.ProductID"
                           class="btn w-50 text-uppercase shadow-sm text-white"
                           style="background-color:black; font-family:'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                                      font-size:13px; line-height:20px;">
                            View Details
                        </a>
                        <a asp-controller="User" asp-action="DeleteProduct" asp-route-id="@product.ProductID"
                           class="btn w-50 text-uppercase shadow-sm text-white"
                           style="background-color:#d7263d; font-family:'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                                      font-size:13px; line-height:20px;">
                            Delete
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
    <nav aria-label="Product pagination" class="mt-5">
        <ul class="pagination justify-content-center flex-wrap rounded-4 py-2 px-3">

            <!-- Previous Button -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link border-0 text-secondary"
                   asp-action="GetAllProducts"
                   asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            <!-- Numbered Pages -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                    <a class="page-link border-0 fw-semibold @(ViewBag.CurrentPage == i ? "text-white bg-dark" : "text-secondary")"
                       style="border-radius: 8px;"
                       asp-action="GetAllProducts"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <!-- Next Button -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link border-0 text-secondary"
                   asp-action=""
                   asp-route-page="@(ViewBag.CurrentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
</div>

<style>
    body {
        background-color: #f5f5f5;
    }
    main{
        margin-top:30px;
        margin-bottom:70px;
    }
    .btn {
        height: 30px;
    }

    .user-row:hover {
        background-color: #f9f9f9;
        transition: background-color 0.2s ease-in-out;
    }
</style>
